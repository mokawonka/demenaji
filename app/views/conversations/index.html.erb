<%# app/views/conversations/index.html.erb
    Single unified view — left panel = conversation list, right panel = chat.
    Works with Turbo.session.drive = false (no Turbo Drive needed).
%>

<div class="messaging-page"
     data-controller="messaging">

  <div class="msg-shell">

    <%# ── LEFT PANEL ── %>
    <div class="conv-panel">
      <div class="conv-header">
        <h2 class="conv-title">Messages</h2>
        <div class="conv-search">
          <span class="conv-search-icon">
            <i class="fa-solid fa-magnifying-glass"></i>
          </span>
          <input
            type="text"
            class="conv-search-input"
            placeholder="Rechercher…"
            data-action="input->messaging#filterConversations"
          />
        </div>
      </div>

      <div class="conv-list">
        <% if @conversations.empty? %>
          <div class="conv-empty">
            <i class="fa-regular fa-comment" style="font-size:28px; color:#ddd; margin-bottom:8px;"></i>
            <p>Aucune conversation</p>
          </div>
        <% else %>
          <% @conversations.each do |conv| %>
            <% other    = conv.user1_id == current_user.id ? conv.user2 : conv.user1 %>
            <% last_msg = conv.messages.order(created_at: :desc).first %>
            <% unread   = conv.messages.unread.where.not(sender_id: current_user.id).count %>

            <div class="conv-item <%= @conversation&.id == conv.id ? 'active' : '' %>"
                 data-conversation-id="<%= conv.id %>"
                 data-action="click->messaging#loadConversation"
                 data-messaging-target="convItem">

              <div class="conv-avatar-wrap">
                <% if other.profile_picture.attached? %>
                  <%= image_tag other.profile_picture, class: "conv-avatar-img" %>
                <% else %>
                  <div class="conv-avatar-initials">
                    <%= other.name.split.map(&:first).first(2).join.upcase %>
                  </div>
                <% end %>
              </div>

              <div class="conv-info">
                <div class="conv-name-row">
                  <span class="conv-name"><%= other.name %></span>
                  <% if last_msg %>
                    <span class="conv-time"><%= l(last_msg.created_at, format: :short) %></span>
                  <% end %>
                </div>
                <div class="conv-preview <%= 'unread' if unread.positive? %>">
                  <% if last_msg %>
                    <%= last_msg.sender_id == current_user.id ? 'Vous : ' : '' %><%= truncate(last_msg.body, length: 42) %>
                  <% else %>
                    Conversation vide
                  <% end %>
                </div>
              </div>

              <% if unread.positive? %>
                <span class="unread-badge"><%= unread %></span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>

    <%# ── RIGHT PANEL ── %>
    <div class="chat-panel">

      <%# Empty state %>
      <div class="chat-empty" id="chat-empty-state"
           style="<%= @conversation ? 'display:none;' : '' %>">
        <div style="width:52px;height:52px;border-radius:50%;background:#f5f5f5;border:0.5px solid #e5e5e5;display:flex;align-items:center;justify-content:center;">
          <i class="fa-regular fa-comment" style="font-size:22px;color:#ccc;"></i>
        </div>
        <p style="font-size:14px;color:#bbb;margin-top:10px;">Sélectionnez une conversation</p>
      </div>

      <%# Chat content — swapped by fetch() in messaging_controller.js %>
      <div id="chat-frame"
           style="<%= @conversation ? 'display:flex; flex:1; flex-direction:column; min-height:0;' : 'display:none;' %>">

        <% if @conversation %>
          <%= render "chat_inner", conversation: @conversation,
                                   other_user: @other_user,
                                   messages: @messages,
                                   current_user: current_user %>
        <% end %>

      </div>

    </div>
  </div>
</div>