<%# app/views/conversations/_chat_inner.html.erb
    Rendered both on initial page load (inside index.html.erb)
    AND returned by conversations#show for the fetch() call.
    Wrap in div#chat-frame-inner so the JS can extract it cleanly.
%>

<div id="chat-frame-inner" style="display:flex; flex:1; flex-direction:column; min-height:0; width:100%;">

  <%# Header %>
  <div class="chat-header">
    <button class="btn-back-mobile d-md-none"
            data-action="click->messaging#backToList">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
    </button>
    <% if other_user.profile_picture.attached? %>
      <%= image_tag other_user.profile_picture, class: "chat-header-avatar-img" %>
    <% else %>
      <div class="chat-header-avatar">
        <%= other_user.name.split.map(&:first).first(2).join.upcase %>
      </div>
    <% end %>
    <div class="chat-header-info">
      <span class="chat-header-name"><%= other_user.name %></span>
    </div>
  </div>

  <%# Messages %>
  <div class="chat-window" id="chat-window">
    <% grouped = messages.group_by { |m| m.created_at.to_date } %>
    <% grouped.each do |date, msgs| %>
      <div class="msg-date-sep">
        <%= date == Date.today ? "Aujourd'hui" :  date.strftime("%-d %B %Y") %>
      </div>
      <% msgs.each do |msg| %>
        <div class="msg-row <%= msg.sender_id == current_user.id ? 'sent' : 'recv' %>"
             id="message_<%= msg.id %>">
          <% unless msg.sender_id == current_user.id %>
            <div class="bubble-avatar">
              <%= other_user.name.split.map(&:first).first(2).join.upcase %>
            </div>
          <% end %>
          <div class="bubble">
            <%= simple_format msg.body, {}, wrapper_tag: :span %>
            <span class="bubble-time"><%= msg.created_at.strftime("%H:%M") %></span>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <%# Input form — id="message-form" is how the JS finds it %>
  <%= form_with url: messages_path,
                method: :post,
                id: "message-form",
                class: "chat-input-area" do |f| %>

    <input type="hidden" name="message[recipient_id]"    value="<%= other_user.id %>">
    <input type="hidden" name="message[conversation_id]" value="<%= conversation.id %>">

    <div class="input-row">
      <%= f.text_area :body,
                      class: "chat-textarea",
                      rows: 1,
                      placeholder: "Écrivez votre message…",
                      data: {
                        messaging_target: "textarea",
                        action: "keydown->messaging#submitOnEnter input->messaging#autoResize"
                      } %>

      <button type="button" class="send-btn"
              data-action="click->messaging#submitForm">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
             stroke="white" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </div>

    <span class="input-hint">Entrée pour envoyer · Maj+Entrée pour une nouvelle ligne</span>
  <% end %>

</div>