<!DOCTYPE html>
<html>
<body style="margin:0; padding:0; background:#f9fafb; font-family:'Helvetica Neue', Arial, sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb; padding:40px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="background:#fff; border-radius:16px; overflow:hidden; box-shadow:0 4px 24px rgba(0,0,0,0.07);">

          <tr>
            <td style="background:#f97316; padding:36px 40px; text-align:center;">
              <h1 style="margin:0; color:#fff; font-size:24px; font-weight:600;">Nouvelle candidature</h1>
              <p style="margin:8px 0 0; color:rgba(255,255,255,0.85); font-size:15px;">
                Pour votre annonce "<%= @place.composed_title %>"
              </p>
            </td>
          </tr>

          <tr>
            <td style="padding:40px;">
              <p style="margin:0 0 20px; font-size:16px; color:#374151;">
                Bonjour <strong><%= @poster.name %></strong>,
              </p>
              <p style="margin:0 0 20px; font-size:15px; color:#6b7280; line-height:1.7;">
                <strong style="color:#374151;"><%= @applicant.name %></strong> 
                vient de postuler à votre annonce. Consultez sa candidature dès maintenant.
              </p>

              <table cellpadding="0" cellspacing="0" style="margin:24px 0;">
                <tr>
                  <td style="background:#f97316; border-radius:999px; padding:14px 32px;">
                    <a href="<%= my_places_url %>"
                       style="color:#fff; font-size:15px; font-weight:600; text-decoration:none;">
                      Voir les candidatures →
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td style="background:#f9fafb; padding:24px 40px; text-align:center; border-top:1px solid #f3f4f6;">
              <p style="margin:0; font-size:12px; color:#9ca3af;">
                © <%= Time.current.year %> Demenaji — Algérie
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>