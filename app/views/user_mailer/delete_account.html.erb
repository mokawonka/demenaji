<!DOCTYPE html>
<html>
<body style="margin:0; padding:0; background:#f9fafb; font-family:'Helvetica Neue', Arial, sans-serif;">

  <table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb; padding: 40px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:16px; overflow:hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.07);">

          <!-- Header -->
          <tr>
            <td style="background:#6b7280; padding: 36px 40px; text-align:center;">
              <h1 style="margin:0; color:#ffffff; font-size:28px; font-weight:600; letter-spacing:-0.5px;">
                Compte supprimé
              </h1>
              <p style="margin: 8px 0 0; color:rgba(255,255,255,0.8); font-size:15px;">
                Nous sommes tristes de vous voir partir
              </p>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding: 40px;">

              <p style="margin: 0 0 20px; font-size:16px; color:#374151; line-height:1.6;">
                Bonjour <strong><%= @user.name %></strong>,
              </p>

              <p style="margin: 0 0 20px; font-size:15px; color:#6b7280; line-height:1.7;">
                Votre compte <strong style="color:#374151;"><%= @user.email %></strong> a bien été 
                supprimé de notre plateforme. Toutes vos données personnelles, annonces et favoris 
                ont été effacés définitivement.
              </p>

              <!-- Info box -->
              <div style="background:#fef3c7; border-radius:12px; padding:20px; margin: 24px 0; border-left: 4px solid #f59e0b;">
                <p style="margin:0; font-size:14px; color:#92400e; line-height:1.6;">
                  <strong>Vous avez supprimé votre compte par erreur ?</strong><br>
                  Malheureusement, cette action est irréversible. Vous pouvez cependant 
                  créer un nouveau compte à tout moment.
                </p>
              </div>

              <!-- CTA -->
              <table cellpadding="0" cellspacing="0" style="margin: 32px 0;">
                <tr>
                  <td style="background:#f97316; border-radius:999px; padding: 14px 32px;">
                    <a href="<%= register_url %>" 
                       style="color:#ffffff; font-size:15px; font-weight:600; text-decoration:none;">
                      Créer un nouveau compte
                    </a>
                  </td>
                </tr>
              </table>

              <hr style="border:none; border-top:1px solid #f3f4f6; margin: 32px 0;">

              <p style="margin:0; font-size:14px; color:#9ca3af; line-height:1.7;">
                Si vous avez des questions ou souhaitez nous faire part de vos retours, 
                n'hésitez pas à nous contacter. Votre avis nous aide à améliorer Demenaji.
              </p>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#f9fafb; padding: 24px 40px; text-align:center; border-top:1px solid #f3f4f6;">
              <p style="margin:0; font-size:12px; color:#9ca3af;">
                Cet email de confirmation a été envoyé suite à la suppression de votre compte.<br>
                © <%= Time.current.year %> Demenaji — Algérie
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>