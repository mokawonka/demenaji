<% content_for :title, 'Mon profil' %>

<div class="container" style="max-width: 600px; padding-top: 40px; padding-bottom: 100px;">

  <h2 class="title" style="margin-bottom: 8px;">Mon profil</h2>
  <p class="fs-12d" style="margin-bottom: 40px;">Gérez vos informations personnelles</p>

  <%= form_with model: @user, url: update_profile_path, method: :patch, multipart: true do |f| %>

    <%# ── Profile Picture ── %>
    <div style="display:flex; flex-direction:column; align-items:center; margin-bottom:40px;">
      <div style="position:relative; display:inline-block;">

        <% if @user.profile_picture.attached? %>
          <%= image_tag @user.profile_picture,
                id: "imagePreview",
                style: "width:150px; height:150px; border-radius:50%; object-fit:cover;
                        border:4px solid #f3f2f2; box-shadow:0 2px 12px rgba(0,0,0,0.10);" %>
        <% else %>
          <div id="imagePreview"
               style="width:120px; height:120px; border-radius:50%; background:#f0f0f0;
                      border:4px solid #f3f2f2; box-shadow:0 2px 12px rgba(0,0,0,0.10);
                      display:flex; align-items:center; justify-content:center;">
            <i class="fa fa-user" style="font-size:48px; color:#ccc;"></i>
          </div>
        <% end %>

        <label for="profile_picture_upload"
               style="position:absolute; bottom:4px; right:4px; width:32px; height:32px;
                      border-radius:50%; background:#ff8138; color:white; cursor:pointer;
                      display:flex; align-items:center; justify-content:center;
                      box-shadow:0 2px 6px rgba(255,129,56,0.4);">
          <i class="fa fa-camera" style="font-size:13px;"></i>
        </label>

        <%= f.file_field :profile_picture,
              id: "profile_picture_upload",
              accept: "image/jpeg,image/png,image/webp",
              style: "display:none;" %>
      </div>
      <p class="fs-12d" style="margin-top:12px; font-size:15px;"><%= @user.name %></p>
    </div>

    <%# ── Form Fields ── %>
    <div style="background:white; border-radius:14px; padding:28px;
                border:1px solid #f0f0f0; margin-bottom:32px;">

      <div class="form-group" style="margin-bottom:20px;">
        <label class="fs-12d" style="text-align:left; margin-bottom:6px; display:block;">
          Nom complet
        </label>
        <%= f.text_field :name,
              value: @user.name,
              placeholder: "Votre nom complet",
              class: "form-control orangeinput",
              style: "border-radius:10px; padding:12px 16px;" %>
      </div>

      <div class="form-group" style="margin-bottom:20px;">
        <label class="fs-12d" style="text-align:left; margin-bottom:6px; display:block;">
          Adresse e-mail
        </label>
        <%= f.email_field :email,
              value: @user.email,
              placeholder: "votre@email.com",
              class: "form-control orangeinput",
              style: "border-radius:10px; padding:12px 16px;" %>
      </div>

      <div class="form-group" style="margin-bottom:20px;">
        <label class="fs-12d" style="text-align:left; margin-bottom:6px; display:block;">
          Profession / Activité
        </label>
        <%= f.text_field :job_title,
              value: @user.job_title,
              placeholder: "ex: Agent immobilier, Étudiant, Enseignant...",
              class: "form-control orangeinput",
              style: "border-radius:10px; padding:12px 16px;" %>
      </div>

      <div class="form-group" style="margin-bottom:0;">
        <label class="fs-12d" style="text-align:left; margin-bottom:6px; display:block;">
          Téléphone
        </label>
        <%= f.text_field :phone_number,
              value: @user.phone_number,
              placeholder: "ex: 0555 00 00 00",
              class: "form-control orangeinput",
              style: "border-radius:10px; padding:12px 16px;" %>
      </div>

    </div>

    <div class="text-center">
      <%= f.submit 'Sauvegarder les modifications', 
            class: 'btn btn-submit btn-lg',
            style: 'border-radius:12px; min-width:220px; padding:14px 32px;' %>
    </div>

  <% end %>
</div>
