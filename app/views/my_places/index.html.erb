<h2 class="title">
  Mes annonces
  <%= image_tag 'img_places.png', class: 'mt-3 mb-5 float-right' %>
</h2>

<% if @my_places.empty? %>
  <div class="container watermark">
    <span class="fs-20">Vous n'avez ajouté aucune annonce pour l'instant.</span>
  </div>

<% else %>
  <form method="post">
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

    <table class="table">
      <tbody>
        <% @my_places.each do |p| %>

          <!-- Place Row -->
          <tr class="beigerow">
            <td class="text-center fs-18">
              <b><%= p.visitor_count %></b> Vues
            </td>
            <td class="text-center fs-18">
              <a href="/Place/<%= p.id %>"><b><%= p.address %></b></a>
            </td>
            <td class="text-center fs-18">
              <b><%= p.number_of_applicants %></b> Postulants
            </td>
            <td class="text-center">
              <a role="button" class="btn btn-sm btn-warning" href="/CreatePlace/<%= p.id %>">Changer</a>
              <button class="btn btn-sm btn-danger" formaction="/MyPlaces/Delete/<%= p.id %>">Supprimer</button>
            </td>
          </tr>

          <!-- Application Rows -->
          <% p.applications.each do |app| %>
            <tr>
              <td class="p-0 text-center fs-15">
                <img class="applicant-profile-pic"
                     src="<%= app.applicant.profile_picture.presence || asset_path('profile_pic.png') %>">
              </td>

              <td class="text-center fs-15">
                <p class="mb-2 mt-2"><%= app.applicant.name %> a postulé.</p>
                <% if app.applicant.job_title.present? %>
                  <span class="d-inline-block">
                    <i>Profession:</i> <b><%= app.applicant.job_title %></b>
                  </span>
                <% end %>
                <% if app.details.present? %>
                  <p class="application-details"><%= app.details %></p>
                <% end %>
              </td>

              <td class="text-center fs-15">
                <% badge_class, label = case app.status
                  when -1      then ['badge-primary', 'En attente']
                  when 0, -2   then ['badge-danger',  'Refusé']
                  when 1       then ['badge-warning',  'Invité']
                  else              ['badge-secondary', 'Inconnu']
                end %>
                <span class="badge badge-pill <%= badge_class %>" style="font-size: 13px; padding: 7px 14px;">
                    <%= label %>
                </span>
              </td>

              <td class="text-center">
                <button formaction="/MyPlaces/Invite/<%= p.id %>/<%= app.id %>"
                        class="btn btn-sm btn-outline-info">Inviter</button>
                <button formaction="/MyPlaces/Decline/<%= p.id %>/<%= app.id %>"
                        class="btn btn-sm btn-outline-danger">Refuser</button>
              </td>
            </tr>
          <% end %>

        <% end %>
      </tbody>
    </table>
  </form>
<% end %>