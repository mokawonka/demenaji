<% content_for :title, 'Mes annonces' %>

<div class="container" style="max-width: 1100px; padding-top: 40px; padding-bottom: 100px;">

  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:8px;">
    <h2 class="title" style="margin-bottom:0;">Mes annonces</h2>
    <%= image_tag 'img_places.png', class: 'mt-3 mb-5', style: 'height:68px;' %>
  </div>
  <p class="fs-12d" style="margin-bottom:40px;">Gérez vos logements et suivez toutes les candidatures reçues</p>

  <% if @my_places.empty? %>
    <div style="background:white; border-radius:14px; padding:60px 40px; border:1px solid #f0f0f0; text-align:center;">
      <div style="font-size:68px; margin-bottom:24px; color:#f0f0f0;">
        <i class="fa fa-home"></i>
      </div>
      <h3 class="fs-20b" style="margin-bottom:12px; color:#777;">Aucune annonce publiée</h3>
      <p class="fs-15" style="color:#bbb; max-width:380px; margin:0 auto 32px;">
        Vous n’avez pas encore mis de logement en location.<br>
        Publiez votre première annonce dès maintenant.
      </p>
      <a href="/CreatePlace" class="btn btn-submit btn-lg" style="border-radius:12px; min-width:220px;">
        Créer une annonce
      </a>
    </div>
  <% else %>

    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(340px, 1fr)); gap:24px;">

      <% @my_places.each do |p| %>
        <div style="background:white; border-radius:14px; padding:24px; border:1px solid #f0f0f0; box-shadow:0 2px 12px rgba(0,0,0,0.06); transition:all 0.2s;">

          <%# Place header %>
          <div style="margin-bottom:16px;">
            <a href="/Place/<%= p.id %>" style="text-decoration:none; color:inherit;">
              <h4 style="margin:0 0 8px; font-size:20px; font-weight:500; line-height:1.3;">
                <%= p.address %>
              </h4>
            </a>
            <div style="display:flex; gap:16px; font-size:14px; color:#777;">
              <span><strong><%= p.visitor_count %></strong> vues</span>
              <span><strong><%= p.number_of_applicants %></strong> candidatures</span>
            </div>
          </div>

          <%# Quick stats + actions %>
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
            <span class="fs-12d">
              Publiée le <%= p.created_at.strftime('%d %B %Y') %>
            </span>

            <div style="display:flex; gap:8px;">
              <a href="/CreatePlace/<%= p.id %>" 
                 class="btn btn-sm" 
                 style="background:#f0f0f0; color:#555; border:none; border-radius:10px; padding:8px 16px; font-size:14px;">
                <i class="fa fa-edit"></i> Modifier
              </a>
              <%= form_with url: "/MyPlaces/Delete/#{p.id}", method: :post, local: true do |f| %>
                <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
                <button type="submit"
                        onclick="return confirm('Supprimer cette annonce ? Toutes les candidatures seront également supprimées.')"
                        class="btn btn-sm"
                        style="background:#f0f0f0; color:#e05252; border:none; border-radius:10px; padding:8px 16px; font-size:14px;">
                  <i class="fa fa-trash"></i> Supprimer
                </button>
              <% end %>
            </div>
          </div>

          <%# Candidatures button – main CTA %>
          <a href="/MyPlaces/<%= p.id %>/applications" 
             class="btn btn-submit btn-lg w-100" 
             style="border-radius:12px; font-size:15px;">
            Voir les candidatures (<%= p.number_of_applicants %>)
          </a>

        </div>
      <% end %>

    </div>

  <% end %>

</div>