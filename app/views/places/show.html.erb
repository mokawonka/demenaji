<% place = @place %>
<% content_for :title, place.composed_title %>

<div class="container">
  <%= csrf_meta_tags %>

  <h2 style="padding-top: 40px;"><%= place.composed_title %></h2>

  <div class="row">

    <!-- Left Column -->
    <div class="col-md-8">

      <!-- Picture Carousel -->
      <% if place.place_pictures.any? %>
      <div class="container mb-5">
        <div id="maincarousel" class="carousel slide" data-interval="false" data-ride="carousel">

          <% if place.place_pictures.size > 1 %>
            <ol class="carousel-indicators">
              <% place.place_pictures.each_with_index do |pic, i| %>
                <li data-target="#maincarousel" 
                    data-slide-to="<%= i %>"
                    class="<%= 'active' if i.zero? %>"></li>
              <% end %>
            </ol>
          <% end %>

          <!-- Slides -->
          <div id="carouselcenter" class="carousel-inner">
            <% place.place_pictures.each_with_index do |pic, i| %>
              <div class="carousel-item <%= 'active' if i.zero? %>">
                <%= image_tag pic.display_url %>
              </div>
            <% end %>
          </div>

          <!-- Navigation arrows -->
          <% if place.place_pictures.size > 1 %>
            <a class="carousel-control-prev" href="#maincarousel" role="button" data-slide="prev">
              <span class="carousel-control-prev-icon" aria-hidden="true"></span>
              <span class="sr-only">Previous</span>
            </a>
            <a class="carousel-control-next" href="#maincarousel" role="button" data-slide="next">
              <span class="carousel-control-next-icon" aria-hidden="true"></span>
              <span class="sr-only">Next</span>
            </a>
          <% end %>

        </div>
      </div>
    <% else %>
      <div class="container mb-5 text-center py-5 text-muted">
        <i class="fa fa-image fa-4x opacity-25 mb-3"></i>
        <p class="fs-17">Pas de photos disponibles</p>
      </div>
    <% end %>

      <!-- Favorite Button -->
      <div class="container pb-5">
        <div class="row">
          <div class="col-7 col-sm-6 pr-0">
              <%= render "shared/socialshare" %> 
          </div>
          <div class="col-5 col-sm-6 pl-0">
            <button id="placeFavorite" class="btn btn-outline-secondary">
              <% if @is_faved %>
                <i id="placeFavSign" class="fa-solid fa-heart"></i>
                <span id="placeFavText" class="d-inline-block"> Favori </span>
              <% else %>
                  <i id="placeFavSign" class="fa-solid fa-plus"></i>
                  <span id="placeFavText" class="d-inline-block"> Favori </span>
              <% end %>
            </button>
          </div>
        </div>
      </div>

      <!-- Description -->
      <div class="container">
        <span class="fw-100">Description</span>
        <p id="addescription" class="fs-18"><%= place.description %></p>
      </div>

      <!-- Apply Button -->
      <form method="post" action="/Place/<%= place.id %>">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <div class="padfifty container text-center pb-5">
          <button type="submit" class="btn btn-submit btn-lg">Postuler</button>
        </div>
      </form>

    </div>

    <!-- Right Column -->
    <div class="col-md-4">
      <div id="admap"
            data-lng="<%= place.gps_longitude %>"
            data-lat="<%= place.gps_latitude %>"></div>

      <div class="container pt-3">
        <p class="fs-15">Adresse: <%= place.address %></p>

        <% if @poster_phone.present? %>
          <% phone_parts = @poster_phone.split('') %>
          <div class="d-flex align-items-center gap-2 mt-2 mb-3"
              style="background:#fff7f0; border:0.5px solid #f5c9a3; border-radius:10px; padding:10px 14px;">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#e87722" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.6 3.39 2 2 0 0 1 3.56 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.87a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/>
            </svg>
            <a id="phone-link"
              href="#"
              class="fs-15"
              style="color:#c0580a; font-weight:500; text-decoration:none; letter-spacing:0.3px;"
              data-p="<%= phone_parts.each_slice(3).map(&:join).join('-') %>"
              data-r="<%= phone_parts.reverse.join %>"
              onclick="revealPhone(this); return false;">
              <span id="phone-reveal" class=ml-3>Afficher le numéro</span>
            </a>
            <span style="margin-left:auto; font-size:11px; color:#e87722; background:#fde8d1; padding:2px 8px; border-radius:20px; cursor:pointer;"
                  onclick="document.getElementById('phone-link').click()">
              Voir
            </span>
          </div>

          <script>
            function revealPhone(el) {
              var r = el.getAttribute('data-r');
              var num = r.split('').reverse().join('');
              document.getElementById('phone-reveal').textContent = num;
              el.href = 'tel:' + num.replace(/\s/g, '');
              el.onclick = null;
              document.querySelector('[onclick*="phone-link"]').style.display = 'none';
            }
          </script>
        <% end %>

        <p class="fs-15"><%= place.number_of_applicants %> postulant(s)</p>
        <span class="fs-15">Posté le <%= l(place.post_date, format: :long) %></span>

        <div class="mt-3 d-flex align-items-center gap-3">
          <span class=pr-2>
            <% if @posterPicture&.attached? %>
              <%= image_tag @posterPicture, class: "mini-profile-pic" %>
            <% else %>
              <%= image_tag 'profile_pic_mini.png', class: "mini-profile-pic" %>
            <% end %>
          </span>
            <span class="fs-15">
              <strong><%= @posterName || "Utilisateur inconnu" %></strong>
            </span>
        </div>

        <%= form_with url: messages_path,  scope: :message, method: :post, class: "text-center border border-light p-1", data: { turbo: false } do |f| %>
          <%= f.hidden_field :recipient_id, value: @place.user_id %>

          <div class="form-group">
            <%= f.text_area :body,
                            spellcheck: true,
                            maxlength: 700,
                            class: "form-control rounded-3",
                            id: "messagearea",
                            rows: 3,
                            placeholder: "Message au propriétaire de l'annonce" %>
          </div>

          <%= f.submit "Envoyer", class: "btn btn-info btn-block" %>
        <% end %>

      </div>
    </div>

  </div>
</div>

<div id="carouselModal" class="modal">
  <span id="carouselModalClose" class="close">&times;</span>

  <span id="modalPrev" class="modal-arrow modal-prev">
    <i class="fa fa-chevron-left"></i>
  </span>

  <img id="carouselModalImg">

  <span id="modalNext" class="modal-arrow modal-next">
    <i class="fa fa-chevron-right"></i>
  </span>
</div>
