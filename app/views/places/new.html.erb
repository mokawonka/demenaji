<% is_new = @place.new_record? %>
<% content_for :title, (is_new ? 'Ajouter une annonce' : "Modifier l'annonce") %>

<div class="container" style="max-width: 800px; padding-top: 40px; padding-bottom: 100px;">

  <h2 class="title" style="margin-bottom: 8px;">
    <%= is_new ? 'Ajouter une annonce' : "Modifier l'annonce" %>
  </h2>
  <p class="fs-12d" style="margin-bottom: 40px;">
    <%= is_new ? 'Publiez votre logement en quelques étapes' : 'Modifiez les informations de votre annonce' %>
  </p>

  <form method="post"
        action="<%= is_new ? '/CreatePlace' : "/CreatePlace/#{@place.id}" %>"
        enctype="multipart/form-data">

    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

    <% unless is_new %>
      <input type="hidden" name="_method" value="patch">
    <% end %>

    <div style="background:white; border-radius:14px; padding:32px; border:1px solid #f0f0f0;">

      <!-- Address -->
      <div class="form-group" style="margin-bottom:24px;">
        <label class="fs-17" style="display:block; margin-bottom:8px;">
          Adresse <span class="starcolor">*</span>
        </label>
        <input name="place[address]"
               value="<%= @place.address %>"
               type="search"
               class="form-control orangeinput"
               id="search-address"
               placeholder="Ex: 123 Rue des Palmiers, Alger"
               style="padding:14px 16px; border-radius:10px;">
        <input id="placeLongitude" type="hidden" name="place[gps_longitude]" value="<%= @place.gps_longitude %>">
        <input id="placeLatitude" type="hidden" name="place[gps_latitude]" value="<%= @place.gps_latitude %>">
      </div>

      <!-- Rent -->
      <div class="form-group" style="margin-bottom:24px;">
        <label class="fs-17" style="display:block; margin-bottom:8px;">
          Loyer mensuel (DA) <span class="starcolor">*</span>
        </label>
        <div class="input-group">
          <input name="place[rent]"
                 value="<%= @place.rent %>"
                 type="number"
                 class="form-control orangeinput"
                 style="padding:14px 16px; border-radius:10px;"
                 placeholder="Ex: 45000">
          <span class="input-group-text" style="background:#f8f9fa;">DA</span>
        </div>
      </div>

      <!-- Nombre de pièces - FIXED -->
      <div class="form-group" style="margin-bottom:24px;">
        <label class="fs-17" style="display:block; margin-bottom:8px;">
          Nombre de pièces <span class="starcolor">*</span>
        </label>
        <select class="form-control orangeinput" 
                name="place[bedrooms]" 
                style="border-radius:10px;">
          <% (0..7).each do |n| %>
            <option value="<%= n %>" <%= 'selected' if @place.bedrooms.to_i == n %>>
              <%= n.zero? ? 'Studio' : "#{n} pièce#{n > 1 ? 's' : ''}" %>
            </option>
          <% end %>
        </select>
      </div>

      <!-- Description -->
      <div class="form-group" style="margin-bottom:32px;">
        <label class="fs-17" style="display:block; margin-bottom:8px;">
          Description <span class="starcolor">*</span>
        </label>
        <textarea name="place[description]"
                  maxlength="3000"
                  rows="6"
                  class="form-control orangeinput"
                  style="padding:14px 16px; border-radius:10px; resize:vertical;"
                  placeholder="Décrivez votre logement (surface, étage, équipements, quartier, etc.)..."><%= @place.description %></textarea>
      </div>

      <!-- Pictures -->
      <div class="form-group">
        <label class="fs-17" style="display:block; margin-bottom:10px;">
          Photos <span class="text-muted fs-12d">(maximum 10 photos, ≤ 8MB chacune)</span>
        </label>

        <div id="dropzone"
             class="border-2 border-dashed border-orange-300 bg-white rounded-3xl p-10 text-center hover:border-orange-400 transition-all cursor-pointer">
          <div class="mx-auto w-20 h-20 bg-orange-100 rounded-2xl flex items-center justify-center mb-5">
            <i class="fa fa-cloud-upload fa-4x text-orange-500"></i>
          </div>
          <p class="fs-17 mb-2">Glissez vos photos ici ou</p>
          <label class="btn btn-browse cursor-pointer inline-flex items-center gap-2 px-5 py-3">
            <i class="fa fa-folder-open"></i>
            Choisir des fichiers
            <input id="file-upload" 
                   type="file" 
                   multiple 
                   name="picture_files[]"
                   accept="image/jpeg,image/png,image/webp"
                   style="display:none;">
          </label>
          <p class="fs-12d mt-4">JPG, PNG, WebP • Taille maximale 8 Mo par photo</p>
        </div>

        <div id="image-preview" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 mt-6"></div>
        <div id="file-count" class="mt-3 fs-12d"></div>
      </div>

    </div>

    <!-- Submit Button -->
    <div class="text-center mt-5">
      <button type="submit" class="btn btn-submit btn-lg" style="min-width: 240px; padding: 14px 40px;">
        <%= is_new ? 'Publier l’annonce' : 'Sauvegarder les modifications' %>
      </button>
    </div>

  </form>
</div>