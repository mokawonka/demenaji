<% is_new = @place.new_record? %>
<% content_for :title, (is_new ? 'Ajouter une annonce' : "Changer l'annonce") %>

<div class="container">
  <h2 class="title">
    <%= is_new ? 'Ajouter une annonce' : "Changer l'annonce" %>
  </h2>

  <form method="post"
        action="<%= is_new ? '/CreatePlace' : "/CreatePlace/#{@place.id}" %>"
        enctype="multipart/form-data">

    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

    <% unless is_new %>
      <input type="hidden" name="_method" value="patch">
    <% end %>

    <!-- Address -->
    <div class="row form-group">
      <label class="fs-17 col-md-3 control-label">
        Adresse<p class="starcolor">*</p>
      </label>
      <div class="col-md-7 has-search">
        <span class="fa fa-search form-control-feedback"></span>
        <input name="place[address]"
               value="<%= @place.address %>"
               type="search"
               class="form-control orangeinput ds-input"
               id="search-address">
        <input id="placeLongitude"
               type="hidden"
               name="place[gps_longitude]"
               value="<%= @place.gps_longitude %>">
        <input id="placeLatitude"
               type="hidden"
               name="place[gps_latitude]"
               value="<%= @place.gps_latitude %>">
      </div>
    </div>

    <!-- Rent -->
    <div class="row form-group">
      <label class="fs-17 col-md-3 control-label">
        Loyer/Prix<p class="starcolor">*</p>
      </label>
      <div class="col-md-3">
        <input name="place[rent]"
               value="<%= @place.rent %>"
               type="number"
               class="form-control orangeinput">
      </div>
    </div>

    <!-- Bedrooms -->
    <div class="row form-group">
      <label class="fs-17 col-md-3 control-label">
        Pièces<p class="starcolor">*</p>
      </label>
      <div class="col-md-3">
        <select class="select-css select-css-orange" name="place[bedrooms]">
          <% (0..7).each do |n| %>
            <option value="<%= n %>" <%= 'selected' if @place.bedrooms.to_i == n %>>
              <%= n.zero? ? 'Studio' : n %>
            </option>
          <% end %>
        </select>
      </div>
    </div>

    <!-- Description -->
    <div class="row form-group">
      <label class="fs-17 col-md-3 control-label">
        Description<p class="starcolor">*</p>
      </label>
      <div class="col-md-7">
        <textarea name="place[description]"
                  maxlength="3000"
                  rows="5"
                  class="form-control orangeinput"><%= @place.description %></textarea>
      </div>
    </div>

    <!-- Pictures -->
    <div class="row form-group">
        <label class="fs-17 col-md-3 control-label">Photos <span class="text-muted">(max 10, ≤8MB)</span></label>
        
        <div class="col-md-9">
            <!-- Drag & Drop Zone -->
            <div id="dropzone"
                class="border-2 border-dashed border-orange-300 bg-white rounded-3xl p-8 text-center hover:border-orange-400 transition-all cursor-pointer">
            <div class="mx-auto w-16 h-16 bg-orange-100 rounded-2xl flex items-center justify-center mb-4">
                <i class="fa fa-cloud-upload fa-3x text-orange-500"></i>
            </div>
            <p class="fs-17 mb-1">Ajouter des photos ici ou</p>
            <label class="btn btn-browse cursor-pointer inline-flex items-center gap-2">
                <i class="fa fa-folder-open"></i>
                Parcourir
                <input id="file-upload" 
                    type="file" 
                    multiple 
                    name="picture_files[]"
                    accept="image/jpeg,image/png,image/webp"
                    style="display:none;">
            </label>
            <p class="fs-12d mt-3">JPG, PNG, WebP • Max 8MB</p>
            </div>

            <!-- Preview Thumbnails -->
            <div id="image-preview" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4 mt-6"></div>

            <!-- Hidden file count (keeps your original #file-count label working) -->
            <div id="file-count" class="mt-3 fs-12d"></div>
        </div>
    </div>

    <!-- Submit -->
    <div class="form-group">
      <div class="text-center">
        <button type="submit" class="btn btn-submit btn-lg">
          <%= is_new ? 'Valider' : 'Sauvegarder' %>
        </button>
      </div>
    </div>

  </form>
</div>