<h2 class="title">
  Favorites
  <%= image_tag 'no_fav.png', class: 'mt-3 float-right' %>
</h2>

<% if @favorites.empty? %>
  <div class="container watermark">
    <span class="fs-20">No Favorites.</span>
  </div>

<% else %>
  <div class="container favorites">
    <form method="post" action="/Favorites">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

      <ul class="list-group-fav">
        <% @favorites.each do |fav| %>
          <% place = fav.place %>
          <% next unless place %>

          <li>
            <a href="/Place/<%= place.id %>"
               class="list-group-item list-group-item-action flex-column align-items-start">
              <div class="row">

                <!-- Delete button + Image -->
                <div class="col-4">
                  <div class="row">
                    <div class="col-6 col-sm-3">
                      <button style="height:40px"
                              class="btn btn-link deletefav"
                              name="fav"
                              value="<%= place.id %>">
                        <i class="fa fa-times text-danger"></i>
                      </button>
                    </div>
                    <div class="col-6 col-sm-9">
                      <%= image_tag(place.place_pictures.first&.inline_src || asset_path('default-place.png'),
                                    class: 'imgpreview') %>
                    </div>
                  </div>
                </div>

                <!-- Rent + Bedrooms -->
                <div class="col-6 offset-2">
                  <h5 class="fw-211">$<%= place.rent %></h5>
                  <p class="fs-17"><%= place.bedroom_label.upcase %></p>
                </div>

              </div>
            </a>
          </li>
        <% end %>
      </ul>

    </form>
  </div>
<% end %>