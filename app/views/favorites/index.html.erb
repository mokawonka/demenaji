<div class="fav-header">
  <h2 class="fav-title">Favoris</h2>
  <% unless @favorites.empty? %>
    <span class="fav-count"><%= @favorites.count %> annonce<%= @favorites.count > 1 ? 's' : '' %></span>
  <% end %>
</div>

<% if @favorites.empty? %>
  <div class="empty-state">
    <div class="empty-icon"><i class="fa-regular fa-heart"></i></div>
    <p class="empty-text">Pas de favoris pour le moment.</p>
  </div>

<% else %>
  <form method="post" action="/Favorites">
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

    <div class="fav-grid">
      <% @favorites.each do |fav| %>
        <% place = fav.place %>
        <% next unless place %>

        <a href="/Place/<%= place.id %>" class="fav-card">
          <div class="fav-img">
            <% if place.place_pictures.any? %>
              <%= image_tag place.place_pictures.first.thumbnail_url %>
            <% else %>
              <%= image_tag 'default-place.png', style: 'width:100%; height:160px; object-fit:cover;' %>
            <% end %>
          </div>
          <div class="fav-body">
            <p class="fav-rent"><%= number_with_delimiter(place.rent) %> DA</p>
            <p class="fav-beds"><%= place.bedroom_label.upcase %></p>
            <p class="fav-addr"><%= place.address %></p>
          </div>
          <div class="fav-footer">
            <span class="fav-date"><%= l(place.post_date, format: :long) if place.post_date %></span>
            <button class="btn-remove" name="fav" value="<%= place.id %>" onclick="event.stopPropagation()">
              &#x2715;
            </button>
          </div>
        </a>

      <% end %>
    </div>
  </form>
<% end %>