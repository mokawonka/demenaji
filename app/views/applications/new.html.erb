<% content_for :title, "Applying To #{@place.address}" %>

<h2>Postuler à <%= @place.address %></h2>

<form method="post" action="/Apply/<%= @place.id %>">
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

  <div class="container">
    <div class="row">

      <!-- Form Fields -->
      <div class="col-md-8">
        <div class="container">

          <!-- Job Title -->
          <div class="row form-group">
            <div class="fs-15 col-md-4 control-label">
              <label class="float-right">Profession</label>
            </div>
            <div class="col-md-4">
              <input name="job_title"
                     class="form-control"
                     value="<%= current_user.job_title %>">
            </div>
          </div>

          <!-- Details -->
          <div class="container">
            <span class="fw-100"> ?</span>
            <div class="container">
              <div class="row form-group">
                <div class="col-md-8">
                  <textarea name="details"
                            rows="3"
                            class="form-control"></textarea>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- Side Image -->
      <div class="col-md-4">
        <%= image_tag 'profile_recap.png', class: 'centerimage pb-5' %>
      </div>

    </div>
  </div>

  <!-- Submit -->
  <div class="text-center pb-5">
    <button type="submit" class="btn btn-submit btn-lg">Postuler</button>
  </div>

</form>